# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (real secrets ignored; sample template committed)
.env*
!.env.sample
!.env.example

# vercel
.vercel

# assignment PDFs (copyrighted, re-downloadable) — keep spec/markdown, drop binaries
/docs/*.pdf

# python forecast job artifacts
forecast/__pycache__/
forecast/.venv/
*.py[cod]

# typescript
*.tsbuildinfo
next-env.d.ts

# personal dev notes
NOTES.md
