# SliceMatic Stage 3 — copy to `.env` and fill in. `.env` is gitignored.
# This file is COMMITTED — keep placeholders only, never real secrets.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API Keys. Use the MODERN keys:
#   • publishable (sb_publishable_...) → browser/anon role
#   • secret      (sb_secret_...)      → server-only, service_role (bypasses RLS)
# The secret key must NEVER be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXX
SUPABASE_SECRET_KEY=sb_secret_XXXXXXXXXXXX

# ── Razorpay ──────────────────────────────────────────────────────────────────
# https://dashboard.razorpay.com → Settings → API Keys. TEST keys for dev.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# Signing secret shown when you create a webhook (Settings → Webhooks).
RAZORPAY_WEBHOOK_SECRET=whsec_XXXXXXXXXXXX
# Public key id used by Checkout.js in the browser (same value as RAZORPAY_KEY_ID).
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX

# ── AI recommendation ─────────────────────────────────────────────────────────
# Provider-agnostic. Develop with OpenAI (your key); switch to "openrouter" for
# the graded submission (the brief mandates OpenRouter). OpenRouter is
# OpenAI-compatible, so the same client code works — only baseURL + model change.
AI_PROVIDER=openai             # openai | openrouter

# -- OpenAI (direct) --
OPENAI_API_KEY=sk-REPLACE_ME --- IGNORE ---
OPENAI_MODEL=gpt-4o-mini

# -- OpenRouter (for submission) --
# OPENROUTER_API_KEY=sk-or-XXXXXXXXXXXX
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Auth / OTP ────────────────────────────────────────────────────────────────
# true → accept the fixed dev code (no SMS sent). Set false + wire a provider for prod.
OTP_MOCK=true
OTP_DEV_CODE=123456

# ── Session (customer mock-OTP cookie) ──
# Any long random string: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_random_32_bytes

# ── Admin (Supabase Auth) — used by `npm run seed:admin` ──
ADMIN_EMAIL=admin@slicematic.local
ADMIN_PASSWORD=change-me-strong

# ── Store location (NEXT_PUBLIC so checkout can geofence client-side) ──
# If the customer's GPS is within TAKEAWAY radius of the store, checkout
# auto-selects take-away/dine-in (they're at the store). Otherwise delivery
# is offered within DELIVERY radius. Restart the dev server after changes.
NEXT_PUBLIC_DELIVERY_RADIUS_KM=4
NEXT_PUBLIC_TAKEAWAY_RADIUS_KM=0.4
NEXT_PUBLIC_SHOP_NAME=SliceMatic
NEXT_PUBLIC_SHOP_AREA=New Ashok Nagar, Delhi
NEXT_PUBLIC_SHOP_LAT=28.5905
NEXT_PUBLIC_SHOP_LNG=77.3037
